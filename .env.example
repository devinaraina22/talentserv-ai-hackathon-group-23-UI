# Clerk Authentication — https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Email (SMTP) — pick ONE Gmail setup (port + SECURE must match!)
#
# Option A — recommended (STARTTLS, port 587):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
#
# Option B — SSL (port 465 only):
# SMTP_PORT=465
# SMTP_SECURE=true
#
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password-no-spaces
SMTP_FROM="MediBook Clinic <your-email@gmail.com>"

# Daily cron for 1-day-before reminders (optional)
CRON_SECRET=your-random-secret-here
